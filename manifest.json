{
  "manifest_version": 3,
  "name": "ClickTimer",
  "short_name": "ClickTimer",
  "version": "0.1.0",
  "description": "Detects times and durations on any webpage and turns them into clickable timers. Perfect for recipes, workouts, tutorials and more.",
  "homepage_url": "https://github.com/dominicware/ClickTimer",
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "ClickTimer",
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/alarm.mp3",
        "assets/fonts/DSEG7Classic-Regular.woff2",
        "assets/clicktimer-logo.svg",
        "assets/icons/icon16.png",
        "assets/icons/icon48.png",
        "assets/icons/icon128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}